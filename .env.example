# Database Credentials (Turso)
# Required for production build and runtime
TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token-here"

# Admin Authentication
# IMPORTANT: Use a strong password (16+ chars, mixed case, numbers, special characters)
ADMIN_PASSWORD="ReplaceThisWithAStrongPassword"

# Google Identity (OAuth)
# Required for Google Sign-In on the account page
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
